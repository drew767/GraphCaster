<Window x:Class="AgentQueueMonitor.MainWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

        mc:Ignorable="d"

        Title="Agent Queue Monitor" Width="1020"

        MinWidth="800"

        SizeToContent="Height"

        ResizeMode="NoResize">

    <DockPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,8,8,4">

            <Button Name="BtnStart" Content="Старт" Width="100" Margin="0,0,8,0" Click="BtnStart_OnClick"/>

            <Button Name="BtnStop" Content="Стоп" Width="100" Margin="0,0,8,0" IsEnabled="False" Click="BtnStop_OnClick"/>

            <Button Name="BtnAfterCycle" Content="Выйти после текущего цикла" MinWidth="220" Margin="0,0,8,0" Padding="12,4" IsEnabled="False" Click="BtnAfterCycle_OnClick"

                    ToolTip="Не запускать следующий цикл: дождаться конца текущего и корректно завершить (файл-флаг рядом со скриптом)."/>

            <Button Name="BtnManualStallRetry" Content="Перезапустить шаг сейчас" MinWidth="200" Margin="0,0,8,0" Padding="12,4" IsEnabled="False" Click="BtnManualStallRetry_OnClick"

                    ToolTip="Создать agent-queue.manual-stall-retry.flag: agent-queue.ps1 прервёт только текущий вызов CLI и перезапустит этот шаг (тот же промпт; без перезапуска pwsh)."/>

            <TextBlock VerticalAlignment="Center" Foreground="Gray" Text="Aura · agent-queue.ps1"/>

        </StackPanel>



        <Grid Margin="8,0,8,8">

            <Grid.RowDefinitions>

                <RowDefinition Height="Auto"/>

                <RowDefinition Height="Auto"/>

                <RowDefinition Height="Auto"/>

            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="300" MinWidth="240"/>

                <ColumnDefinition Width="*"/>

            </Grid.ColumnDefinitions>



            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" BorderBrush="#CCC" BorderThickness="1" Padding="10,8" Margin="0,0,0,8" Background="#FAFAFA">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*" MinWidth="160"/>

                        <ColumnDefinition Width="*" MinWidth="140"/>

                        <ColumnDefinition Width="*" MinWidth="100"/>

                        <ColumnDefinition Width="*" MinWidth="180"/>

                        <ColumnDefinition Width="*" MinWidth="180"/>

                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">

                        <TextBlock Text="Фаза" FontSize="11" Foreground="Gray"/>

                        <TextBlock Name="TxtPhase" Text="—" TextWrapping="Wrap" FontSize="15" FontWeight="SemiBold"/>

                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,8,0">

                        <TextBlock FontSize="11" Foreground="Gray" Text="Таймер">

                            <TextBlock.ToolTip>

                                <TextBlock TextWrapping="Wrap" MaxWidth="320"

                                           Text="Время с последнего обновления agent-queue.monitor-status.json. Пока идёт шаг Cursor CLI, файл может не меняться — смотрите окно консоли."/>

                            </TextBlock.ToolTip>

                        </TextBlock>

                        <TextBlock Name="TxtStall" Text="—" TextWrapping="Wrap" FontSize="15" FontWeight="SemiBold"/>

                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,8,0">

                        <TextBlock FontSize="11" Foreground="Gray" Text="Цикл">

                            <TextBlock.ToolTip>

                                <TextBlock TextWrapping="Wrap" MaxWidth="320"

                                           Text="Pipeline: текущий глобальный цикл (-Cycles). Sequential: раунд (-Loop)."/>

                            </TextBlock.ToolTip>

                        </TextBlock>

                        <TextBlock Name="TxtCycle" Text="—" TextWrapping="Wrap" FontSize="15" FontWeight="SemiBold"/>

                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="0,0,8,0">

                        <TextBlock Text="Текущий шаг" FontSize="11" Foreground="Gray"/>

                        <TextBlock Name="TxtCurrentStep" Text="—" TextWrapping="Wrap" FontSize="13"/>

                    </StackPanel>

                    <StackPanel Grid.Column="4">

                        <TextBlock Text="Следующий в очереди" FontSize="11" Foreground="Gray"/>

                        <TextBlock Name="TxtNextStep" Text="—" TextWrapping="Wrap" FontSize="13"/>

                    </StackPanel>

                </Grid>

            </Border>



            <DockPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" MinHeight="120"

                       Height="{Binding ElementName=ParamsScrollViewer, Path=ActualHeight, Mode=OneWay}">

                <TextBlock DockPanel.Dock="Top" FontWeight="Bold" Margin="0,0,0,4" Text="Файл промптов"/>

                <ListBox Name="PromptFilesList" SelectionChanged="PromptFilesList_OnSelectionChanged"/>

            </DockPanel>



            <ScrollViewer Name="ParamsScrollViewer" Grid.Row="1" Grid.Column="1" VerticalAlignment="Top"

                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,0">

                <StackPanel Name="ParamsStackPanel">

                    <TextBlock FontWeight="Bold" Margin="0,0,0,6" Text="Параметры"/>

                    <Grid>

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="240"/>

                            <ColumnDefinition Width="*"/>

                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>

                            <RowDefinition Height="Auto"/>

                            <RowDefinition Height="Auto"/>

                            <RowDefinition Height="Auto"/>

                            <RowDefinition Height="Auto"/>

                            <RowDefinition Height="Auto"/>

                            <RowDefinition Height="Auto"/>

                            <RowDefinition Height="Auto"/>

                            <RowDefinition Height="Auto"/>

                        </Grid.RowDefinitions>



                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap" Text="Корень репозитория (Workspace)"/>

                        <TextBox Name="TxtWorkspace" Grid.Row="0" Grid.Column="1" Margin="0,2"/>



                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap" Text="Модель"/>

                        <ComboBox Name="CmbModel" Grid.Row="1" Grid.Column="1" Margin="0,2" IsEditable="False"

                                  ToolTip="Имя модели для --model. Список из Cursor CLI: agent models."/>



                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap" Text="Режим CLI (Mode)"/>

                        <ComboBox Name="CmbMode" Grid.Row="2" Grid.Column="1" Margin="0,2"

                                 ToolTip="agent — правки; plan/ask — без записи (см. справку скрипта).">

                            <ComboBoxItem Content="agent" IsSelected="True"/>

                            <ComboBoxItem Content="plan"/>

                            <ComboBoxItem Content="ask"/>

                        </ComboBox>



                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap" Text="Количество циклов к выполнению"/>

                        <TextBox Name="TxtCycles" Grid.Row="3" Grid.Column="1" Margin="0,2" Text="100"

                                 ToolTip="-Cycles"/>



                        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap" Text="Начать с блока №"/>

                        <TextBox Name="TxtStartFromPrompt" Grid.Row="4" Grid.Column="1" Margin="0,2" Text="1"

                                 ToolTip="-StartFromPrompt: номер блока (1-based)."/>



                        <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap" Text="Циклов на один чат"/>

                        <TextBox Name="TxtCyclesPerChat" Grid.Row="5" Grid.Column="1" Margin="0,2" Text="3"

                                 ToolTip="-CyclesPerChat"/>



                        <CheckBox Name="ChkStartNewChat" Grid.Row="6" Grid.Column="1" Margin="0,4" IsChecked="True"

                                  ToolTip="Включено: первый промпт — новый чат (без --continue). Снять: первый промпт с --continue — продолжить последний чат Cursor для этого workspace.">

                            <TextBlock TextWrapping="Wrap" Text="Начинать в новом чате"/>

                        </CheckBox>



                        <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap" Text="Таймер автоперезапуска, с"/>

                        <TextBox Name="TxtStallRestartSeconds" Grid.Row="7" Grid.Column="1" Margin="0,2" Text="1200"

                                 ToolTip="Полная длительность таймера в секундах: если agent-queue.monitor-status.json не обновлялся дольше этого времени — создаётся флаг перезапуска шага (как у кнопки). 0 = только ручной перезапуск. По умолчанию 1200."/>

                    </Grid>

                </StackPanel>

            </ScrollViewer>



            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">

                <TextBlock FontWeight="Bold" Margin="0,0,0,4" Text="Лог событий монитора"/>

                <TextBox Name="TxtLog" MinHeight="72" IsReadOnly="True" VerticalScrollBarVisibility="Auto"

                         TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"/>

            </StackPanel>

        </Grid>

    </DockPanel>

</Window>
