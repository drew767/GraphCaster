{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://graphcaster.local/schemas/graph-document.schema.json",
  "title": "GraphCaster graph document (v1.3)",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "nodes", "edges"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "schemaVersion": { "type": "integer" },
        "graphId": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "author": { "type": "string" }
      }
    },
    "viewport": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "zoom": { "type": "number" }
      }
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "position", "data"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "minLength": 1,
          "description": "Known kinds: start, exit, task, graph_ref, comment, merge (join paths after branch; F18 in/out_default only). Other values: unknown executable (task-like handles in validation)."
        },
        "position": {
          "type": "object",
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          },
          "additionalProperties": true
        },
        "data": {
          "type": "object",
          "additionalProperties": true
        },
        "parentId": {
          "type": "string",
          "minLength": 1,
          "description": "Optional id of a comment frame this node belongs to (editor-only grouping)."
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "target"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "sourceHandle": {
          "type": "string",
          "description": "Source handle id: out_default (success path) or out_error (failure path after task/graph_ref failure; Dify FAIL_BRANCH-style). See python/README.md."
        },
        "targetHandle": { "type": "string" },
        "source_handle": { "type": "string" },
        "target_handle": { "type": "string" },
        "condition": {
          "description": "Empty/null: unconditional. Max 65536 chars after trim. Literals true/false/1/0/yes/no. Mustache templates: {{dotted.path}} or {{dotted.path}} op literal (==, !=, <, <=, >, >=); n8n-style paths without eval. JSON object starting with { but not {{: JSON Logic subset. Other strings: truthiness of last_result. See python/README.md.",
          "oneOf": [{ "type": "null" }, { "type": "string" }]
        }
      }
    }
  }
}
