{
  "schemaVersion": 1,
  "graphId": "trigger-poll-github-releases",
  "meta": {
    "schemaVersion": 1,
    "graphId": "trigger-poll-github-releases",
    "title": "GitHub Releases RSS polling trigger example"
  },
  "viewport": { "x": 0, "y": 0, "zoom": 1 },
  "nodes": [
    {
      "id": "poll1",
      "type": "trigger_poll",
      "position": { "x": 0, "y": 0 },
      "data": {
        "title": "GitHub Releases RSS",
        "kind": "rss",
        "url": "https://github.com/python/cpython/releases.atom",
        "intervalSec": 300,
        "compareMode": "newest-item",
        "timeoutSec": 30
      }
    },
    {
      "id": "t1",
      "type": "task",
      "position": { "x": 300, "y": 0 },
      "data": {
        "title": "Process new release",
        "command": "echo",
        "argv": ["echo", "New release detected"]
      }
    },
    {
      "id": "x1",
      "type": "exit",
      "position": { "x": 600, "y": 0 },
      "data": { "title": "Done" }
    }
  ],
  "edges": [
    {
      "id": "e1",
      "source": "poll1",
      "sourceHandle": "out_default",
      "target": "t1",
      "targetHandle": "in_default",
      "condition": null
    },
    {
      "id": "e2",
      "source": "t1",
      "sourceHandle": "out_default",
      "target": "x1",
      "targetHandle": "in_default",
      "condition": null
    }
  ]
}
