      "data": {
        "title": "Remove temp files",
        "command": "sh",
        "argv": ["sh", "-c", "rm -rf /tmp/gc-workspace-tmp/* && echo 'Cleaned up temp files'"],
        "successMode": "exit_code",
        "timeoutSec": 60
      }
    },
    {
