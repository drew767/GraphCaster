    {
      "id": "s1",
      "type": "trigger_schedule",
      "position": { "x": 0, "y": 0 },
      "data": {
        "title": "Daily at midnight",
        "cron": "0 0 * * *",
        "timezone": "UTC"
      }
    },
    {
