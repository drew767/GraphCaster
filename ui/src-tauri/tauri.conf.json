{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GraphCaster",
  "version": "0.1.0",
  "identifier": "com.graphcaster.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "GraphCaster",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "GraphCaster",
    "category": "DeveloperTool",
    "shortDescription": "Visual editor for directed scenario graphs.",
    "longDescription": "Install GraphCaster to edit flow graphs in a native window. On first run Windows may install the Edge WebView2 runtime (the installer handles this automatically). No Python or Rust is required to use the installed app.",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "Russian"],
        "displayLanguageSelector": false,
        "startMenuFolder": "GraphCaster"
      }
    }
  }
}
